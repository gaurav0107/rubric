{
  "name": "rubric",
  "version": "2.2.0",
  "description": "Pairwise prompt evaluation framework — CLI and local server.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "rubric": "./src/bin.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:binary": "bun build ./src/bin.ts --compile --outfile ./dist/rubric",
    "build:binary:linux-x64": "bun build ./src/bin.ts --compile --target bun-linux-x64 --outfile ./dist/rubric-linux-x64",
    "build:binary:linux-arm64": "bun build ./src/bin.ts --compile --target bun-linux-arm64 --outfile ./dist/rubric-linux-arm64",
    "build:binary:darwin-x64": "bun build ./src/bin.ts --compile --target bun-darwin-x64 --outfile ./dist/rubric-darwin-x64",
    "build:binary:darwin-arm64": "bun build ./src/bin.ts --compile --target bun-darwin-arm64 --outfile ./dist/rubric-darwin-arm64",
    "build:binary:windows-x64": "bun build ./src/bin.ts --compile --target bun-windows-x64 --outfile ./dist/rubric-windows-x64.exe",
    "build:binary:all": "bun run build:binary:linux-x64 && bun run build:binary:linux-arm64 && bun run build:binary:darwin-x64 && bun run build:binary:darwin-arm64 && bun run build:binary:windows-x64"
  },
  "dependencies": {
    "@rubric/shared": "*"
  }
}
